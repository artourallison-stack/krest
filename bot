<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>Viral Studio Mini App</title>
    <!-- Telegram WebApp SDK -->
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&display=swap');
        
        body {
            background-color: var(--tg-theme-bg-color, #f3f4f6);
            color: var(--tg-theme-text-color, #111827);
            font-family: 'Inter', sans-serif;
            margin: 0;
            padding: 20px;
            overflow-x: hidden;
            -webkit-tap-highlight-color: transparent;
        }

        .card {
            background: var(--tg-theme-secondary-bg-color, #ffffff);
            border-radius: 24px;
            padding: 20px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.05);
            margin-bottom: 20px;
        }

        #renderCanvas {
            width: 100%;
            aspect-ratio: 9/16;
            background: #000;
            border-radius: 16px;
            display: none;
            margin-bottom: 15px;
        }

        .btn-main {
            background: var(--tg-theme-button-color, #0088cc);
            color: var(--tg-theme-button-text-color, #ffffff);
            font-weight: 800;
            padding: 16px;
            border-radius: 16px;
            width: 100%;
            transition: transform 0.1s;
        }
        .btn-main:active { transform: scale(0.97); }
        .btn-main:disabled { opacity: 0.5; cursor: not-allowed; }

        .progress-container {
            width: 100%; height: 6px; background: #e5e7eb;
            border-radius: 3px; overflow: hidden; display: none; margin-top: 15px;
        }
        #progress-fill { height: 100%; width: 0%; background: #10b981; transition: width 0.1s linear; }

        video {
            width: 100%; border-radius: 16px; margin-top: 20px; background: #000; display: none;
        }
    </style>
</head>
<body>

    <div id="app">
        <!-- Расписание -->
        <div class="flex justify-between items-center mb-6 px-2">
            <div>
                <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Ереван</p>
                <p class="text-lg font-black">16:45 & 21:30</p>
            </div>
            <div class="bg-blue-100 text-blue-700 text-[10px] font-black px-2 py-1 rounded">
                US TARGET 🇺🇸
            </div>
        </div>

        <div class="card">
            <h1 class="text-xl font-black mb-1">30 Days Automation</h1>
            <p class="text-xs text-gray-500 mb-4 font-medium">Генерация видео-дилемм для TikTok</p>

            <select id="daySelect" class="w-full p-4 bg-gray-50 border-2 border-gray-100 rounded-xl font-bold mb-4 outline-none focus:border-blue-500">
                <!-- Дни добавятся динамически -->
            </select>

            <div class="bg-gray-50 p-4 rounded-xl mb-4 border border-gray-100">
                <div class="flex justify-between items-center mb-1">
                    <span class="text-[10px] font-bold text-gray-400 uppercase">Metadata</span>
                    <button id="copyBtn" class="text-[10px] font-bold text-blue-600 uppercase">Copy</button>
                </div>
                <p id="metaTitle" class="text-xs font-bold leading-tight mb-1"></p>
                <p id="metaTags" class="text-[10px] text-blue-500 font-medium"></p>
            </div>

            <button id="renderBtn" class="btn-main">
                <i class="fa-solid fa-wand-magic-sparkles mr-2"></i> СГЕНЕРИРОВАТЬ
            </button>

            <div class="progress-container" id="pContainer">
                <div id="progress-fill"></div>
            </div>
            <p id="status" class="text-center text-[10px] font-bold text-gray-400 mt-2 uppercase"></p>
        </div>

        <!-- Видимый рендер (Нужен для iOS) -->
        <canvas id="renderCanvas" width="1080" height="1920"></canvas>
        
        <!-- Результат -->
        <video id="outputVideo" controls playsinline></video>
        
        <div id="finalActions" class="hidden mt-4 space-y-3">
            <div class="bg-green-50 p-3 rounded-xl border border-green-100 text-center">
                <p class="text-green-700 text-xs font-bold">Видео готово! Зажми его, чтобы сохранить.</p>
            </div>
            <button id="sendToTgBtn" class="w-full bg-blue-500 text-white font-black py-4 rounded-xl text-sm">
                <i class="fa-brands fa-telegram mr-1"></i> ОТПРАВИТЬ МНЕ В ЛИЧКУ
            </button>
        </div>
    </div>

    <script>
        // Инициализация Telegram WebApp
        const tg = window.Telegram.WebApp;
        tg.expand();
        tg.ready();

        const BOT_TOKEN = "8471256787:AAF9Eq1mtOpOkvGMi7mngkNYtpM-Ee4CI7s";
        const apiKey = ""; // API Key Gemini

        const daysDB = [
            { h: "Only 1% of people pass this psychological test.", a: "Get $10,000,000 right now.", b: "Go back to age 10 with all knowledge." },
            { h: "The Ultimate Moral Dilemma.", a: "Save your best friend.", b: "Save 100 strangers." },
            { h: "The Memory Test. What do you value more?", a: "Erase worst 5 years.", b: "See 5 years into future." },
            { h: "The Truth Paradox.", a: "Always know the truth.", b: "Never get caught lying." },
            { h: "The Loyalty Test.", a: "Find true love, lose friends.", b: "Keep friends, never find love." }
        ];

        const select = document.getElementById('daySelect');
        const metaTitle = document.getElementById('metaTitle');
        const metaTags = document.getElementById('metaTags');
        const canvas = document.getElementById('renderCanvas');
        const ctx = canvas.getContext('2d');
        const renderBtn = document.getElementById('renderBtn');
        const progressFill = document.getElementById('progress-fill');
        const pContainer = document.getElementById('pContainer');
        const status = document.getElementById('status');
        const outputVideo = document.getElementById('outputVideo');
        const finalActions = document.getElementById('finalActions');

        let isRendering = false;
        let finalBlob = null;

        // Настройка списка дней
        daysDB.forEach((d, i) => {
            const opt = document.createElement('option');
            opt.value = i; opt.text = `Day ${i+1}: ${d.h.substring(0,30)}...`;
            select.appendChild(opt);
        });

        function updateMeta() {
            const data = daysDB[select.value];
            metaTitle.innerText = `Day ${parseInt(select.value)+1}/30. What's your choice? Be honest. 🤔👇`;
            metaTags.innerText = "#wouldyourather #psychologytest #choices #mindset";
        }
        select.addEventListener('change', updateMeta);
        updateMeta();

        // Отрисовка кадра
        function drawFrame(data, progress, day) {
            const w = canvas.width; const h = canvas.height;
            
            // Превью-обложка на первые 0.5 сек
            if (progress < 0.05) {
                ctx.fillStyle = '#0f172a'; ctx.fillRect(0,0,w,h);
                ctx.fillStyle = '#fff'; ctx.font = '900 100px Inter'; ctx.textAlign = 'center';
                ctx.fillText("WHICH DO YOU", w/2, h/2 - 50);
                ctx.fillStyle = '#f43f5e'; ctx.fillText("CHOOSE?", w/2, h/2 + 80);
                return;
            }

            // Основной дизайн
            ctx.fillStyle = '#ffffff'; ctx.fillRect(0, 0, w, h);
            ctx.fillStyle = '#f43f5e'; 
            // Бейдж
            ctx.beginPath(); ctx.roundRect(w/2-140, 100, 280, 65, 32); ctx.fill();
            ctx.fillStyle = '#fff'; ctx.font = '800 35px Inter'; ctx.textAlign = 'center';
            ctx.fillText(`DAY ${day} / 30`, w/2, 145);

            ctx.fillStyle = '#1e293b'; ctx.font = '800 70px Inter';
            const words = data.h.split(' ');
            ctx.fillText(words.slice(0, 4).join(' '), w/2, 320);
            ctx.fillText(words.slice(4).join(' '), w/2, 410);

            if (progress > 0.2) {
                ctx.save(); ctx.translate(w/2, 800);
                ctx.fillStyle = '#ef4444'; ctx.beginPath(); ctx.roundRect(-420, -220, 840, 440, 50); ctx.fill();
                ctx.fillStyle = '#fff'; ctx.font = '900 45px Inter'; ctx.fillText("OPTION A", 0, -120);
                ctx.font = '700 55px Inter'; ctx.fillText(data.a, 0, 50); ctx.restore();
            }
            if (progress > 0.45) {
                ctx.save(); ctx.translate(w/2, 1400);
                ctx.fillStyle = '#3b82f6'; ctx.beginPath(); ctx.roundRect(-420, -220, 840, 440, 50); ctx.fill();
                ctx.fillStyle = '#fff'; ctx.font = '900 45px Inter'; ctx.fillText("OPTION B", 0, -120);
                ctx.font = '700 55px Inter'; ctx.fillText(data.b, 0, 50); ctx.restore();
            }
        }

        async function getVoice(text) {
            const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-tts:generateContent?key=${apiKey}`;
            const payload = {
                contents: [{ parts: [{ text }] }],
                generationConfig: { responseModalities: ["AUDIO"], speechConfig: { voiceConfig: { prebuiltVoiceConfig: { voiceName: "Puck" } } } },
                model: "gemini-2.5-flash-preview-tts"
            };
            const r = await fetch(url, { method: 'POST', body: JSON.stringify(payload) });
            const json = await r.json();
            return json.candidates[0].content.parts[0].inlineData.data;
        }

        renderBtn.addEventListener('click', async () => {
            if (isRendering) return;
            isRendering = true;
            renderBtn.disabled = true;
            outputVideo.style.display = 'none';
            finalActions.style.display = 'none';
            canvas.style.display = 'block';
            pContainer.style.display = 'block';
            status.innerText = "Подготовка ИИ...";

            const dayIdx = parseInt(select.value);
            const data = daysDB[dayIdx];
            const voiceText = `${data.h} Option A: ${data.a}. Or Option B: ${data.b}. Comment below!`;

            try {
                const AudioContext = window.AudioContext || window.webkitAudioContext;
                const actx = new AudioContext();
                // Разблокировка звука iOS
                const silentBuf = actx.createBuffer(1, 1, 22050);
                const s = actx.createBufferSource(); s.buffer = silentBuf; s.connect(actx.destination); s.start(0);

                const b64 = await getVoice(voiceText);
                const bytes = Uint8Array.from(atob(b64), c => c.charCodeAt(0));
                
                // WAV Header Fix
                const header = new Uint8Array([82,73,70,70,0,0,0,0,87,65,86,69,102,109,116,32,16,0,0,0,1,0,1,0,128,187,0,0,0,119,1,0,2,0,16,0,100,97,116,97,0,0,0,0]);
                const fullWav = new Uint8Array(header.length + bytes.length);
                fullWav.set(header); fullWav.set(bytes, header.length);
                
                const audioBuf = await actx.decodeAudioData(fullWav.buffer);
                const duration = audioBuf.duration + 0.5;

                status.innerText = "Рендер видео...";
                const stream = canvas.captureStream(30);
                const dest = actx.createMediaStreamDestination();
                const combined = new MediaStream([...stream.getVideoTracks(), ...dest.stream.getAudioTracks()]);
                
                const rec = new MediaRecorder(combined, { mimeType: 'video/mp4', videoBitsPerSecond: 6000000 });
                const chunks = [];
                rec.ondataavailable = e => chunks.push(e.data);
                
                rec.onstop = () => {
                    finalBlob = new Blob(chunks, { type: 'video/mp4' });
                    outputVideo.src = URL.createObjectURL(finalBlob);
                    outputVideo.style.display = 'block';
                    canvas.style.display = 'none';
                    pContainer.style.display = 'none';
                    finalActions.style.display = 'block';
                    status.innerText = "Готово!";
                    isRendering = false;
                    renderBtn.disabled = false;
                };

                const source = actx.createBufferSource();
                source.buffer = audioBuf;
                source.connect(dest); source.connect(actx.destination);

                rec.start();
                source.start(0);
                const start = Date.now();
                
                const loop = () => {
                    if (!isRendering) return;
                    const elapsed = (Date.now() - start) / 1000;
                    const progress = Math.min(elapsed / duration, 1);
                    progressFill.style.width = (progress * 100) + '%';
                    drawFrame(data, progress, dayIdx + 1);
                    if (progress < 1) requestAnimationFrame(loop); else rec.stop();
                };
                loop();

            } catch (e) {
                alert("Ошибка! Проверь интернет. " + e);
                location.reload();
            }
        });

        // ПРЯМАЯ ОТПРАВКА В ЛИЧКУ
        document.getElementById('sendToTgBtn').addEventListener('click', async () => {
            const btn = document.getElementById('sendToTgBtn');
            btn.disabled = true;
            btn.innerText = "ОТПРАВЛЯЮ...";

            const user = tg.initDataUnsafe.user;
            const chat_id = user ? user.id : prompt("Введите ваш Telegram ID (узнать в @userinfobot):");

            if (!chat_id || !finalBlob) return;

            const fd = new FormData();
            fd.append("chat_id", chat_id);
            fd.append("video", finalBlob, `Day_${parseInt(select.value)+1}.mp4`);
            fd.append("caption", metaTitle.innerText + "\n\n" + metaTags.innerText);

            try {
                const resp = await fetch(`https://api.telegram.org/bot${BOT_TOKEN}/sendVideo`, {
                    method: 'POST', body: fd
                });
                if (resp.ok) {
                    tg.HapticFeedback.notificationOccurred('success');
                    alert("Успешно! Видео прилетело тебе в чат с ботом.");
                } else {
                    throw new Error();
                }
            } catch (e) {
                alert("Ошибка отправки. Сохрани видео долгим нажатием.");
            }
            btn.disabled = false;
            btn.innerText = "ОТПРАВИТЬ МНЕ В ЛИЧКУ";
        });
    </script>
</body>
</html>

